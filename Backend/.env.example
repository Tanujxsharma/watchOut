# Server Configuration
PORT=5000
FRONTEND_URL=http://localhost:5173

# Firebase Admin SDK Configuration
# Get these from your Firebase Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# NOTE: When pasting the private key, keep the \n characters or ensure newlines are preserved
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_API_KEY=your-firebase-web-api-key

# Cloudinary Configuration
# Get these from your Cloudinary Dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Government Admin Credentials
# These are the credentials you will use to log in to the /government/login page
GOVT_ADMIN_EMAIL=admin@government.gov
GOVT_ADMIN_PASSWORD=secure-password-or-bcrypt-hash

# Security
# Random string for signing JWT tokens
JWT_SECRET=your-super-secret-jwt-key-change-this
